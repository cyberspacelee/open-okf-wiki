# Copy this file to .env (project root or beside wiki-run.yaml).
# The CLI loads it with override=False: existing process environment always wins.
# Set PYTHON_DOTENV_DISABLED=1 to skip local .env loading.
#
# Secrets never go in wiki-run.yaml — only environment / secret managers.
# Check presence (no raw secrets): okf-wiki doctor

# ---------------------------------------------------------------------------
# OpenAI and OpenAI-compatible Chat Completions APIs
# ---------------------------------------------------------------------------
# Used when model is openai:… / openai-chat:… / openai-responses:…
# Works with OpenAI, vLLM, LiteLLM, OpenRouter-compatible proxies, DeepSeek,
# Ollama openai-compatible mode, etc.
# Base URL must be the API root the OpenAI SDK expects (usually ends with /v1).
#
# Preflight: OPENAI_API_KEY is required unless OPENAI_BASE_URL is set (local
# servers that ignore auth may omit the key).

OPENAI_API_KEY=replace-me
# OPENAI_BASE_URL=https://api.openai.com/v1
# Examples:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# Optional OpenAI organization / project selection
# OPENAI_ORG_ID=organization-id
# OPENAI_PROJECT_ID=project-id

# ---------------------------------------------------------------------------
# Other Pydantic AI providers (when model uses their prefix)
# ---------------------------------------------------------------------------
# Preflight checks these when the model identity uses the matching prefix.
# ANTHROPIC_API_KEY=replace-me
# GOOGLE_API_KEY=replace-me
# GEMINI_API_KEY=replace-me
# AZURE_OPENAI_API_KEY=replace-me
# AZURE_OPENAI_ENDPOINT=https://example.openai.azure.com
# OPENROUTER_API_KEY=replace-me

# ---------------------------------------------------------------------------
# Product defaults (non-secret; YAML and CLI override these when set)
# ---------------------------------------------------------------------------
# Model identity as provider:name. For compatible gateways use openai:<served-name>.
# OKF_WIKI_MODEL=openai:gpt-5-mini

# Per-completion max output tokens (ModelSettings.max_tokens)
# OKF_WIKI_MAX_TOKENS=8192

# Sampling temperature (0–2)
# OKF_WIKI_TEMPERATURE=0.2

# Compaction / operational context target (not the provider hard window)
# OKF_WIKI_CONTEXT_TARGET_TOKENS=100000

# Run-level cumulative usage budgets (UsageLimits)
# OKF_WIKI_INPUT_TOKENS_LIMIT=250000
# OKF_WIKI_OUTPUT_TOKENS_LIMIT=100000
# OKF_WIKI_TOTAL_TOKENS_LIMIT=350000

# Provider HTTP request timeout (seconds); also used as ModelSettings.timeout default
# OKF_WIKI_REQUEST_TIMEOUT_SECONDS=120

# Optional: write secret-scrubbed failure diagnostics on error (path or 1/auto)
# OKF_WIKI_ERROR_DUMP=1
