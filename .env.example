# Copy to untracked `.env` (or export in the shell).
# Process environment always wins over files the server may load later.
# Secrets never go in workspace.json.

# OpenAI and OpenAI-compatible Chat Completions (Mastra model router).
# Base URL must be the API root (usually ends with /v1).
OPENAI_API_KEY=replace-me
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1

# Agent mode: omit for auto (fixture when no key/URL; live when configured).
# OKF_WIKI_AGENT_MODE=fixture
# OKF_WIKI_AGENT_MODE=live

# Local server (defaults shown)
# OKF_WIKI_HOST=127.0.0.1
# OKF_WIKI_PORT=8787
# OKF_WIKI_HOME=~/.okf-wiki

# LAN access (explicit opt-in; binds all interfaces when host is 0.0.0.0)
# OKF_WIKI_ALLOW_LAN=1
# OKF_WIKI_HOST=0.0.0.0
# Web UI on another machine must point at this host:
# VITE_API_BASE=http://192.168.x.x:8787
