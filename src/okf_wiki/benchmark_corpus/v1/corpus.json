{
  "version": "v1",
  "release_baseline": {
    "pydantic_ai": "2.8.0"
  },
  "features": [
    "conflicting_sources",
    "dto_heavy_java",
    "java_spring",
    "markdown_requirements",
    "multi_module",
    "multi_repository"
  ],
  "producer_project": {
    "id": "order-platform",
    "source_ids": ["orders", "contracts", "requirements"]
