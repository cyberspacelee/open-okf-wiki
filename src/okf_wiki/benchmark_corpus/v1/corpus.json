          "mode": "100644",
          "content": "#!/bin/sh\nexec gradle \"$@\"\n"
        },
        {
          "path": "settings.gradle",
          "mode": "100644",
          "content": "include 'orders-domain', 'orders-api'\n"
        },
        {
          "path": "orders-api/src/main/java/example/OrderController.java",
          "mode": "100644",
          "content": "@RestController class OrderController { @PostMapping OrderResponse create(@RequestBody CreateOrderRequest request) { return service.create(request); } }\n"
        },
        {
          "path": "orders-domain/src/main/java/example/OrderService.java",
          "mode": "100644",
          "content": "@Service class OrderService { Order create(CreateOrder command) { return repository.save(command); } }\n"
        }
      ]
    },
    {
      "id": "contracts",
      "role": "reference",
      "revision": "b6ede90be6580e40dd2b415f91a75c71e0618e90",
      "files": [
        {
          "path": "src/main/java/example/CreateOrderRequest.java",
          "mode": "100644",
          "content": "record CreateOrderRequest(String customerId, java.util.List<LineItemRequest> lines, String currency) {}\n"
        },
        {
          "path": "src/main/java/example/OrderResponse.java",
          "mode": "100644",
          "content": "record OrderResponse(String id, String status, long totalMinor, String currency, java.time.Instant createdAt) {}\n"
        },
        {
          "path": "src/main/java/example/LineItemRequest.java",
          "mode": "100644",
          "content": "record LineItemRequest(String sku, int quantity, long unitPriceMinor) {}\n"
        }
      ]
    },
    {
