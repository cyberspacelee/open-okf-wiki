    "test": "node --experimental-strip-types --test src/**/*.test.ts"
  },
  "dependencies": {
    "@okf-wiki/agent": "workspace:*",
    "@okf-wiki/contract": "workspace:*",
    "@okf-wiki/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.9.3"
  }
}
