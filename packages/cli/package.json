{
  "name": "@okf-wiki/cli",
  "version": "0.2.0-dev",
  "private": true,
  "type": "module",
  "bin": {
    "okf-wiki": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --experimental-strip-types src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@okf-wiki/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.9.3"
  }
}
